# 混沌思维蒸馏系统 - 环境变量配置示例

# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# 服务器配置
PORT=3000
HOST=localhost
NODE_ENV=development

# 数据库配置
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/chaos-skill.db
DATABASE_LOGGING=false

# 安全配置
API_KEY=your_api_key_here
CORS_ORIGIN=http://localhost:3000,https://localhost:3000

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/chaos-skill.log
LOG_MAX_SIZE=100MB
LOG_MAX_FILES=14d

# 性能配置
CACHE_ENABLED=true
CACHE_TTL=3600
CONCURRENCY_MAX=10
CONCURRENCY_TIMEOUT=120000

# 思维蒸馏配置
MODEL_COUNT=5
COLLISION_INTENSITY=high
QUALITY_THRESHOLD=0.7
UNCERTAINTY_THRESHOLD=0.15
VALIDATION_QUESTIONS=3

# 开发配置
DEBUG=true
HOT_RELOAD=true
AUTO_UPDATE=true

# 外部服务配置
EXTERNAL_API_TIMEOUT=30000
EXTERNAL_API_RETRY_COUNT=3

# 监控配置
METRICS_ENABLED=true
METRICS_PORT=3001
METRICS_PATH=/metrics

# 数据存储配置
STORAGE_PATH=./data
MODEL_PATH=./models
CACHE_PATH=./cache
LOGS_PATH=./logs

# 系统配置
SYSTEM_NAME=混沌思维蒸馏系统
SYSTEM_VERSION=1.0.0
SYSTEM_DESCRIPTION=超越单一视角的多维度思维分析平台

# 安全警告：
# - 请不要将真实的 API 密钥提交到版本控制系统
# - 在生产环境中，应使用更安全的密钥管理方式
# - 定期轮换 API 密钥以提高安全性
